# ─── Backend API ───────────────────────────────────────────────────────────────
# URL của FastAPI server (local hoặc production)
NEXT_PUBLIC_API_URL=your_url

# ─── WebSocket ─────────────────────────────────────────────────────────────────
# URL WebSocket để stream transcript realtime
NEXT_PUBLIC_WS_URL=your_url

# ─── Groq API (nếu gọi từ frontend — không khuyến khích cho prod) ──────────────
# Tốt hơn: để FastAPI xử lý, frontend chỉ gọi qua /api/*
GROQ_API_KEY=your_groq_api_key_here

# ─── App metadata ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=MediScribeAI
NEXT_PUBLIC_APP_URL=your_url_here
